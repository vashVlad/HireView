# HireView — environment configuration template
#
# Copy to .env.local for development, or set these as environment variables
# in your hosting platform (Vercel: Project Settings → Environment Variables).
# Never commit a real .env.local or equivalent — .gitignore already excludes
# .env* project-wide.

# --- Anthropic (required) ---
# Server-side only — never exposed to the client. Used for JD analysis,
# resume scoring, credibility checks, and vision-based text extraction.
ANTHROPIC_API_KEY=

# --- Supabase (required) ---
# Service-role key — server-side only, bypasses RLS. Used by lib/supabase.ts
# for all data reads/writes. Get both from Supabase Dashboard → Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public/browser-safe Supabase keys — used for Supabase Auth session handling
# (middleware.ts, lib/supabase-server.ts, lib/supabase-browser.ts). The anon
# key is safe to expose; RLS policies (or the absence thereof — see the
# migration runbook) govern what it can actually read/write.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional ---
# Resend API key. If unset, email notifications (feedback form, access
# requests) are silently skipped — the underlying feature (saving to the DB)
# still works without it.
RESEND_API_KEY=

# Where feedback/access-request notification emails are sent. If unset,
# falls back to a hardcoded default in the two routes that use it — set this
# explicitly for any deployment other than the original personal instance.
NOTIFICATION_EMAIL=

# Public base URL of this deployment, used to build links inside notification
# emails (e.g. "Review in HireView →"). If unset, falls back to the original
# personal deployment's URL — set this explicitly for any other deployment.
NEXT_PUBLIC_APP_URL=
